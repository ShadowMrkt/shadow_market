// frontend/jest.config.js
// --- REVISION HISTORY ---
// 2025-04-08: Rev 8 - Added module mapper for @/context, refined CSS module mapping.
//           - Added '^@/context/(.*)$' mapping to fix module resolution error.
//           - Explicitly added/prioritized mapping for `.module.css` files for identity-obj-proxy.
// 2025-04-08: Rev 7 - Removed next/jest wrapper entirely. Relies on .babelrc.js. (Fixed JSX error).
// (Previous revisions omitted)

/** @type {import('jest').Config} */
const config = {
	clearMocks: true,
	testEnvironment: 'jest-environment-jsdom',
	setupFilesAfterEnv: ['<rootDir>/jest.setup.js'], // For @testing-library/jest-dom matchers
	transform: {
	  // Use babel-jest to transpile JS/JSX/TS/TSX files
	  // Requires .babelrc.js with presets: ['next/babel']
	  '^.+\\.(js|jsx|ts|tsx)$': 'babel-jest',
	},
	transformIgnorePatterns: [
	  // Ignore node_modules and PnP paths from Babel transformation
	  '/node_modules/',
	  '\\.pnp\\.[^\\/]+$',
	],
	moduleNameMapper: {
	  // --- CSS Modules & CSS imports ---
	  // Use identity-obj-proxy to mock CSS Modules and standard CSS imports
	  // Map the specific *.module.css pattern first
	  '^.+\\.module\\.(css|sass|scss)$': 'identity-obj-proxy',
	  // Then map general CSS/SCSS/LESS (if needed)
	  '\\.(css|less|sass|scss)$': 'identity-obj-proxy',
  
	  // --- Module Path Aliases ---
	  // Ensure these match the 'paths' in your tsconfig.json or jsconfig.json
	  '^@/components/(.*)$': '<rootDir>/components/$1',
	  '^@/pages/(.*)$': '<rootDir>/pages/$1',
	  '^@/utils/(.*)$': '<rootDir>/utils/$1',
	  '^@/lib/(.*)$': '<rootDir>/lib/$1',
	  '^@/styles/(.*)$': '<rootDir>/styles/$1',
	  '^@/context/(.*)$': '<rootDir>/context/$1', // <-- ADDED for AuthContext alias
  
	  // --- Static Asset Mocks ---
	  // Mock file imports for images, fonts, etc.
	  '\\.(gif|ttf|eot|svg|png|jpg|jpeg)$': '<rootDir>/__mocks__/fileMock.js', // Requires mock file
	},
	// Ignore paths when searching for tests
	testPathIgnorePatterns: [
	  '<rootDir>/node_modules/',
	  '<rootDir>/.next/',
	],
	// Add other Jest options if needed...
  };
  module.exports = config;