# .env Template for Shadow Market Backend

# Django Secret Key (Generate a secure key using Python: 
# import secrets; print(secrets.token_urlsafe(50)))
DJANGO_SECRET_KEY=your_production_secret_key

# Debug mode (set to False in production)
DEBUG=False

# Allowed hosts (comma-separated list; include your domain, localhost, etc.)
DJANGO_ALLOWED_HOSTS=yourdomain.com,localhost,127.0.0.1

# Sentry DSN for error logging (if using Sentry)
SENTRY_DSN=your_sentry_dsn_here

# PostgreSQL Database Configuration
POSTGRES_DB=mymarketplace
POSTGRES_USER=mymarketplaceuser
POSTGRES_PASSWORD=securepassword
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Security Settings
DJANGO_SECURE_SSL_REDIRECT=True
SITE_DOMAIN=https://yourdomain.com

# Celery Configuration (Redis as broker)
CELERY_BROKER_URL=redis://redis:6379/0

# Encryption Key for Order Messages (Generate a secure 32-byte key)
ORDER_MESSAGE_KEY=32_byte_random_string_here________

# Operator Bitcoin Wallet Address (for fee collection)
OPERATOR_BTC_ADDRESS=your_operator_btc_address_here

# GnuPG Home Directory (path where GnuPG stores keys)
GPG_HOME=/secure/path/to/gnupg

# Google reCAPTCHA Secret Key (for protecting login and forms)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Site Owner Username (for administrative functions)
SITE_OWNER_USERNAME=your_site_owner_username
